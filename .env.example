# Google OAuth (https://console.cloud.google.com/apis/credentials)
# Buat OAuth 2.0 Client ID tipe "Web application"
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# PostgreSQL (contoh: postgresql://user:password@localhost:5432/temenin)
DATABASE_URL=postgresql://postgres:password@localhost:5432/temenin

# Secret untuk JWT session (gunakan string acak panjang di production)
JWT_SECRET=change-me-to-a-long-random-string
